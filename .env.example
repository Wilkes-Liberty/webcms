# WilkesLiberty CMS — environment variable template
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# This file is safe to commit. The .env file is gitignored.
# For DDEV: set variables in .ddev/config.yaml under web_environment[].
# For Docker: these are passed in via docker-compose.yml / .env in the infra repo.

# ── AI / OpenAI (drupal/ai module) ──────────────────────────────────────────
# API keys for AI-assisted content features. Managed via drupal/key module.
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=   # Uncomment if Anthropic provider is enabled

# ── Translation (drupal/tmgmt) ───────────────────────────────────────────────
# If using an external MT provider (DeepL, Google, etc.)
# DEEPL_API_KEY=
# GOOGLE_TRANSLATE_API_KEY=

# ── Next.js / Decoupled integration ─────────────────────────────────────────
# These must match the values in infra/docker/.env (Docker) or be set manually.
# Used by the Drupal "next" module to revalidate the Next.js frontend cache.
NEXT_DRUPAL_CLIENT_ID=drupal-client
NEXT_DRUPAL_CLIENT_SECRET=
DRUPAL_REVALIDATE_SECRET=

# ── Keycloak / OpenID Connect ────────────────────────────────────────────────
# Configured in Drupal's OpenID Connect module settings (not via env vars directly).
# Store the client secret via the drupal/key module pointing to an env variable.
KEYCLOAK_CLIENT_SECRET=

# ── Notes ────────────────────────────────────────────────────────────────────
# Database credentials are NOT set here — they come from:
#   DDEV:   settings.ddev.php (auto-generated by DDEV)
#   Docker: settings.docker.php (mounted as settings.local.php)
#
# The hash_salt is also not here — it must be set in settings.local.php:
#   $settings['hash_salt'] = 'your-random-string-here';
#   Generate one: drush ev 'echo \Drupal\Component\Utility\Crypt::randomBytesBase64(55);'
