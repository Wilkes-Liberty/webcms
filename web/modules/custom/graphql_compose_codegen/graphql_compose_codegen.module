<?php

/**
 * @file
 * Hooks for graphql_compose_codegen.
 *
 * Watches for content-model changes (new bundles, new/removed field storages)
 * and logs actionable notices so developers know when to re-run
 * `drush gqcc:generate`.
 */

declare(strict_types=1);

/**
 * Implements hook_entity_bundle_create().
 */
function graphql_compose_codegen_entity_bundle_create(string $entity_type_id, string $bundle): void {
  if ($entity_type_id !== 'node') {
    return;
  }
  \Drupal::logger('graphql_compose_codegen')->notice(
    'New node bundle "@bundle" created. Run <code>drush gqcc:generate --bundles=@bundle --output-dir=/path/to/nextjs</code> to scaffold TypeScript types, GraphQL fragments, and a component stub.',
    ['@bundle' => $bundle]
  );
}

/**
 * Implements hook_entity_bundle_delete().
 */
function graphql_compose_codegen_entity_bundle_delete(string $entity_type_id, string $bundle): void {
  if ($entity_type_id !== 'node') {
    return;
  }
  \Drupal::logger('graphql_compose_codegen')->warning(
    'Node bundle "@bundle" deleted. Manually remove the corresponding TypeScript type from <code>types/index.d.ts</code>, the inline fragment from <code>node-by-path.ts</code>, and the NodeRenderer case.',
    ['@bundle' => $bundle]
  );
}

/**
 * Implements hook_field_storage_config_insert().
 */
function graphql_compose_codegen_field_storage_config_insert(\Drupal\field\FieldStorageConfigInterface $field_storage): void {
  if ($field_storage->getTargetEntityTypeId() !== 'node') {
    return;
  }
  $bundles = implode(',', array_keys($field_storage->getBundles()));
  \Drupal::logger('graphql_compose_codegen')->notice(
    'New field "@field" (@type) added to bundle(s) [@bundles]. Run <code>drush gqcc:generate --bundles=@bundles --output-dir=/path/to/nextjs --overwrite</code> to update scaffolding.',
    [
      '@field'   => $field_storage->getName(),
      '@type'    => $field_storage->getType(),
      '@bundles' => $bundles,
    ]
  );
}

/**
 * Implements hook_field_storage_config_delete().
 */
function graphql_compose_codegen_field_storage_config_delete(\Drupal\field\FieldStorageConfigInterface $field_storage): void {
  if ($field_storage->getTargetEntityTypeId() !== 'node') {
    return;
  }
  \Drupal::logger('graphql_compose_codegen')->warning(
    'Field storage "@field" deleted. Manually remove references from TypeScript types and GraphQL fragments in your Next.js project.',
    ['@field' => $field_storage->getName()]
  );
}
