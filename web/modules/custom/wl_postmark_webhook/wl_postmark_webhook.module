<?php

/**
 * Implements hook_mail_alter().
 *
 * Blocks outbound email to addresses that have previously bounced hard or
 * filed a spam complaint. Soft/transient bounces suppress for a configurable
 * window; hard bounces and spam complaints suppress permanently (or per the
 * complaint_suppression_days setting).
 */
function wl_postmark_webhook_mail_alter(array &$message): void {
  $config = \Drupal::config('wl_postmark_webhook.settings');
  if (!$config->get('enabled')) {
    return;
  }

  $to = trim($message['to'] ?? '');
  if ($to === '') {
    return;
  }

  // Strip display name if present: "Name <email>" → "email".
  if (preg_match('/<([^>]+)>/', $to, $m)) {
    $to = $m[1];
  }

  $reason = _wl_postmark_webhook_suppression_reason($to, $config);
  if ($reason !== NULL) {
    $message['send'] = FALSE;
    \Drupal::logger('wl_postmark_webhook')->info(
      'Suppressed outbound email to %to: %reason',
      ['%to' => $to, '%reason' => $reason]
    );
  }
}

/**
 * Returns a human-readable suppression reason string, or NULL if not suppressed.
 *
 * Bounce type classification:
 *   Permanent (no window): HardBounce, BadEmailAddress, ManuallyDeactivated,
 *     Unsubscribe, SpamComplaint, SpamNotification
 *   Temporary (bounce_suppression_days window): Transient, SoftBounce, DnsError,
 *     MailboxFull, MessageTooLarge
 *   Log-only (no suppression): Delivery, Open, Click, Subscribe, and unknowns
 */
function _wl_postmark_webhook_suppression_reason(string $email, $config): ?string {
  $db = \Drupal::database();
  $now = \Drupal::time()->getRequestTime();

  $hard_bounce_types  = ['HardBounce', 'BadEmailAddress', 'ManuallyDeactivated', 'Unsubscribe'];
  $soft_bounce_types  = ['Transient', 'SoftBounce', 'DnsError', 'MailboxFull', 'MessageTooLarge'];
  $spam_event_types   = ['SpamComplaint', 'SpamNotification'];

  // ── Spam complaints ──────────────────────────────────────────────────────
  $complaint_days = (int) $config->get('complaint_suppression_days');
  $spam_query = $db->select('postmark_events', 'pe')
    ->fields('pe', ['event_type', 'created'])
    ->condition('recipient', $email)
    ->condition('event_type', $spam_event_types, 'IN')
    ->orderBy('created', 'DESC')
    ->range(0, 1);
  // 0 = permanent: no date filter. Positive = time-limited window.
  if ($complaint_days > 0) {
    $spam_query->condition('created', $now - ($complaint_days * 86400), '>=');
  }
  $spam = $spam_query->execute()->fetchObject();
  if ($spam) {
    return 'spam complaint (' . $spam->event_type . ') on ' . date('Y-m-d', $spam->created);
  }

  // ── Hard bounces (permanent) ─────────────────────────────────────────────
  $hard = $db->select('postmark_events', 'pe')
    ->fields('pe', ['bounce_type', 'created'])
    ->condition('recipient', $email)
    ->condition('event_type', 'Bounce')
    ->condition('bounce_type', $hard_bounce_types, 'IN')
    ->orderBy('created', 'DESC')
    ->range(0, 1)
    ->execute()
    ->fetchObject();
  if ($hard) {
    return 'hard bounce (' . $hard->bounce_type . ') on ' . date('Y-m-d', $hard->created);
  }

  // ── Soft bounces (time-limited) ───────────────────────────────────────────
  $bounce_days = (int) $config->get('bounce_suppression_days');
  if ($bounce_days > 0) {
    $soft = $db->select('postmark_events', 'pe')
      ->fields('pe', ['bounce_type', 'created'])
      ->condition('recipient', $email)
      ->condition('event_type', 'Bounce')
      ->condition('bounce_type', $soft_bounce_types, 'IN')
      ->condition('created', $now - ($bounce_days * 86400), '>=')
      ->orderBy('created', 'DESC')
      ->range(0, 1)
      ->execute()
      ->fetchObject();
    if ($soft) {
      return 'soft bounce (' . $soft->bounce_type . ') on ' . date('Y-m-d', $soft->created)
        . " (within {$bounce_days}-day suppression window)";
    }
  }

  return NULL;
}
